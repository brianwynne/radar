{
  "name": "@radar/data",
  "version": "0.1.0",
  "private": true,
  "description": "RADAR persistence boundary — framework-independent repository contracts, PostgreSQL implementations and source-controlled schema migrations. No Fastify/HTTP/React dependencies; talks to any driver satisfying a minimal Queryable.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --exclude \"**/integration/**\"",
    "test:unit": "vitest run --exclude \"**/integration/**\"",
    "test:integration": "vitest run integration",
    "test:integration:postgres": "vitest run integration",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "@types/pg": "8.20.0",
    "pg": "8.22.0",
    "pg-mem": "3.0.14",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
