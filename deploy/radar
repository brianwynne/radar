#!/usr/bin/env bash
#
# radar — management CLI for a RADAR install.
#
#   radar upgrade [--version vX.Y.Z] [--arch amd64|arm64]   Download, verify and apply a release
#   radar rollback                                          Reinstall the previously-installed version
#   radar cert --domain <fqdn> [--email <addr>]             Issue a Let's Encrypt cert (opens/closes 80)
#   radar status                                            Service + health + installed version
#   radar version                                           Print the installed version
#   radar start | stop | restart                            Control the API service
#   radar logs [-f] [-n N]                                  Tail the API journal
#   radar set-token [<token>]                               Store a GitHub token (private-repo releases)
#   radar uninstall                                         Remove services (keeps data + config)
#
# The upgrade path reuses the release bundle's own idempotent installer, so an upgrade is exactly a
# fresh install against existing config/secrets/database: code is swapped in /opt/radar, migrations
# run, services restart. Nothing here writes to NS1 or any upstream.
set -euo pipefail

REPO="brianwynne/radar"
OPT_DIR="/opt/radar"
ETC_DIR="/etc/radar"
TOKEN_FILE="${ETC_DIR}/.github-token"
PREV_FILE="${ETC_DIR}/.previous-version"
API_HEALTH="http://127.0.0.1:3000/api/v1/health/live"

log()  { printf '\033[1;34m[radar]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[radar]\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[radar] ERROR:\033[0m %s\n' "$*" >&2; exit 1; }
need_root() { [ "$(id -u)" -eq 0 ] || die "this command must be run as root (use sudo)."; }

installed_version() {
  if [ -f "${OPT_DIR}/VERSION" ]; then cat "${OPT_DIR}/VERSION"
  elif [ -f "${OPT_DIR}/apps/api/package.json" ]; then node -p "require('${OPT_DIR}/apps/api/package.json').version" 2>/dev/null || echo unknown
  else echo "not installed"; fi
}

resolve_token() {
  if [ -n "${GITHUB_TOKEN:-}" ]; then printf '%s' "$GITHUB_TOKEN"; return; fi
  [ -f "$TOKEN_FILE" ] && cat "$TOKEN_FILE" || true
}

# Evaluate a JS expression against the parsed JSON on stdin. `d` = parsed object, `a` = $2.
json() {
  node -e 'const d=JSON.parse(require("fs").readFileSync(0,"utf8"));const a=process.argv[2];const v=new Function("d","a","return "+process.argv[1])(d,a);process.stdout.write(v==null?"":String(v))' "$1" "${2:-}"
}

gh_get() { # $1 = repo path (e.g. /releases/latest); adds auth + JSON accept
  local token auth=(); token="$(resolve_token)"; [ -n "$token" ] && auth=(-H "Authorization: Bearer $token")
  curl -fsSL "${auth[@]}" -H "Accept: application/vnd.github+json" -H "X-GitHub-Api-Version: 2022-11-28" "https://api.github.com/repos/${REPO}$1"
}

gh_download_asset() { # $1 = asset id, $2 = output path
  local token auth=(); token="$(resolve_token)"; [ -n "$token" ] && auth=(-H "Authorization: Bearer $token")
  curl -fL "${auth[@]}" -H "Accept: application/octet-stream" "https://api.github.com/repos/${REPO}/releases/assets/$1" -o "$2"
}

cmd_upgrade() {
  case " $* " in *" -h "*|*" --help "*) echo "usage: radar upgrade [--version vX.Y.Z] [--arch amd64|arm64]"; return 0 ;; esac
  need_root
  command -v node >/dev/null || die "node is required (should be installed by RADAR)."
  local tag="" arch; arch="$(dpkg --print-architecture)"
  while [ $# -gt 0 ]; do
    case "$1" in
      --version|--tag) tag="${2:-}"; shift 2 ;;
      --arch) arch="${2:-}"; shift 2 ;;
      -h|--help) echo "usage: radar upgrade [--version vX.Y.Z] [--arch amd64|arm64]"; return 0 ;;
      *) die "unknown option: $1" ;;
    esac
  done

  local relpath; if [ -n "$tag" ]; then relpath="/releases/tags/${tag}"; else relpath="/releases/latest"; fi
  log "Resolving release (${tag:-latest})…"
  local rel; rel="$(gh_get "$relpath")" || die "could not fetch release ${tag:-latest} for ${REPO}. Private repo? Run: sudo radar set-token"
  tag="$(printf '%s' "$rel" | json 'd.tag_name')"
  [ -n "$tag" ] || die "release metadata had no tag."
  local asset="radar-${tag}-linux-${arch}.tar.gz"
  local asset_id; asset_id="$(printf '%s' "$rel" | json '(d.assets.find(x=>x.name===a)||{}).id' "$asset")"
  [ -n "$asset_id" ] || die "release ${tag} has no asset '${asset}'."
  local sum_id; sum_id="$(printf '%s' "$rel" | json '(d.assets.find(x=>x.name===a)||{}).id' "${asset}.sha256")"

  local cur; cur="$(installed_version)"
  local tmp; tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' RETURN
  log "Downloading ${asset}…"
  gh_download_asset "$asset_id" "${tmp}/${asset}"
  if [ -n "$sum_id" ]; then
    gh_download_asset "$sum_id" "${tmp}/${asset}.sha256"
    log "Verifying checksum…"
    ( cd "$tmp" && sha256sum -c "${asset}.sha256" ) >/dev/null || die "checksum verification FAILED — aborting."
  else
    warn "no checksum asset for ${asset}; skipping verification."
  fi

  log "Extracting…"
  tar -C "$tmp" -xzf "${tmp}/${asset}"
  local bundle="${tmp}/radar-${tag}-linux-${arch}"
  [ -x "${bundle}/deploy/install.sh" ] || die "extracted bundle is missing deploy/install.sh."

  [ "$cur" = "not installed" ] || printf '%s' "$cur" > "$PREV_FILE" 2>/dev/null || true
  log "Applying ${tag} (idempotent upgrade over existing config/data)…"
  ( cd "$bundle" && ./deploy/install.sh )
  log "Done: ${cur} → ${tag}."
}

cmd_rollback() {
  need_root
  local prev; prev="$(cat "$PREV_FILE" 2>/dev/null || true)"
  [ -n "$prev" ] || die "no previous version recorded to roll back to."
  log "Rolling back to ${prev}…"
  cmd_upgrade --version "$prev"
}

cmd_cert() {
  case " $* " in *" -h "*|*" --help "*) echo "usage: radar cert --domain <fqdn> [--email <addr>] [--staging]"; return 0 ;; esac
  need_root
  command -v certbot >/dev/null || die "certbot is not installed (the installer adds it)."
  local domain="" email="" extra=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --domain|-d) domain="${2:-}"; shift 2 ;;
      --email|-m)  email="${2:-}"; shift 2 ;;
      --staging)   extra+=(--staging); shift ;;
      -h|--help)   echo "usage: radar cert --domain <fqdn> [--email <addr>] [--staging]"; return 0 ;;
      *) extra+=("$1"); shift ;;
    esac
  done
  [ -n "$domain" ] || die "a domain is required: radar cert --domain radar.example.ie --email you@example.ie"
  install -d -o root -g root -m 0755 /var/www/certbot

  # Open port 80 for the HTTP-01 challenge, issue, then close it again (renewals do the same via
  # certbot's pre/post hooks). The deploy hook installs the cert to /etc/radar/tls and reloads nginx.
  log "Opening port 80 for the ACME challenge…"
  ufw allow 80/tcp >/dev/null 2>&1 || true
  local reg=(--register-unsafely-without-email); [ -n "$email" ] && reg=(--email "$email")
  set +e
  certbot certonly --webroot -w /var/www/certbot -d "$domain" \
    --non-interactive --agree-tos --keep-until-expiring "${reg[@]}" "${extra[@]}"
  local rc=$?
  set -e
  log "Closing port 80…"
  ufw delete allow 80/tcp >/dev/null 2>&1 || true
  [ "$rc" -eq 0 ] || die "certbot failed (exit ${rc}). Check that ${domain} resolves to this host and DNS/port 80 are reachable."
  log "Certificate issued for ${domain}. nginx now serves it (installed to /etc/radar/tls)."
  log "Renewals are automatic (certbot.timer) and open/close port 80 by themselves."
}

cmd_status() {
  echo "RADAR version : $(installed_version)"
  systemctl is-active --quiet radar-api.service && echo "radar-api     : active" || echo "radar-api     : inactive"
  systemctl is-enabled --quiet radar-api.service 2>/dev/null && echo "on boot       : enabled" || echo "on boot       : disabled"
  if curl -fsS "$API_HEALTH" >/dev/null 2>&1; then echo "API health    : OK"; else echo "API health    : NOT responding"; fi
  echo "last migrate  : $(systemctl show -p ExecMainStatus --value radar-migrate.service 2>/dev/null | sed 's/^0$/success (exit 0)/')"
}

case "${1:-}" in
  upgrade)   shift; cmd_upgrade "$@" ;;
  rollback)  shift; cmd_rollback "$@" ;;
  cert)      shift; cmd_cert "$@" ;;
  status)    cmd_status ;;
  version)   installed_version ;;
  start)     need_root; systemctl start radar-api.service; log "started." ;;
  stop)      need_root; systemctl stop radar-api.service; log "stopped." ;;
  restart)   need_root; systemctl restart radar-migrate.service; systemctl restart radar-api.service; systemctl reload nginx 2>/dev/null || true; log "restarted." ;;
  logs)      shift; exec journalctl -u radar-api.service "$@" ;;
  set-token) shift; need_root
             tok="${1:-}"; [ -n "$tok" ] || { read -rsp "GitHub token: " tok; echo; }
             install -d -o root -g root -m 0750 "$ETC_DIR"
             umask 077; printf '%s' "$tok" > "$TOKEN_FILE"; chmod 0600 "$TOKEN_FILE"; chown root:root "$TOKEN_FILE"
             log "GitHub token saved to ${TOKEN_FILE} (root-only)." ;;
  uninstall) need_root
             log "Stopping and disabling services (data in Postgres and ${ETC_DIR} are kept)…"
             systemctl disable --now radar-api.service radar-migrate.service 2>/dev/null || true
             rm -f /etc/systemd/system/radar-api.service /etc/systemd/system/radar-migrate.service
             systemctl daemon-reload
             log "Removed services. To fully remove: rm -rf ${OPT_DIR} ${ETC_DIR} and drop the 'radar' DB/role." ;;
  ""|-h|--help|help)
             cat <<'USAGE'
radar — manage a RADAR install

  radar upgrade [--version vX.Y.Z] [--arch amd64|arm64]   Download, verify and apply a release
  radar rollback                                          Reinstall the previous version
  radar cert --domain <fqdn> [--email <addr>] [--staging] Issue a Let's Encrypt cert (opens/closes 80)
  radar status                                            Service + health + installed version
  radar version                                           Installed version
  radar start | stop | restart                            Control the API service
  radar logs [-f] [-n N]                                  Tail the API journal (journalctl args)
  radar set-token [<token>]                               Store a GitHub token for private releases
  radar uninstall                                         Remove services (keeps data + config)
USAGE
             ;;
  *) die "unknown command: $1 (try: radar help)" ;;
esac
