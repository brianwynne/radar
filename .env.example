# RADAR environment (copy to .env for local development). Never commit real secrets.

# --- Mode -------------------------------------------------------------------
# mock  = fixture-backed NS1 adapter, no NS1 credential required (default for dev)
# live  = real NS1 Connect, read-only API key required
RADAR_MODE=mock

# --- NS1 Connect (read-only, GET-only; radar-api only; never sent to the browser) ---
# HTTPS only. In live mode the base must be https and a read-only key is required.
NS1_API_BASE=https://api.nsone.net/v1
# Preferred: mount the key at /run/secrets/ns1_api_key. For local dev only, this env var:
NS1_API_KEY=
NS1_REQUEST_TIMEOUT_MS=5000
NS1_MAX_RETRIES=2
NS1_CACHE_TTL_SECONDS=30

# --- Change detection (NS1 Activity-API polling; off by default; needs a database) -----
# When enabled, RADAR polls GET /v1/account/activity and, only on a relevant change,
# fetches the affected record, captures a snapshot and re-evaluates Live Steering.
CHANGE_DETECTION_ENABLED=false
CHANGE_DETECTION_INTERVAL_MS=30000

# --- Network-path telemetry (read-only, INFORMATIONAL — never modifies NS1 steering) ---
# disabled   = utilisation shown as "Telemetry not connected" (default)
# mock       = deterministic synthetic data, clearly labelled MOCK / SYNTHETIC
# prometheus = real read-only Prometheus instant queries (see below)
NETWORK_TELEMETRY_MODE=disabled
# Observations older than this are marked STALE (last value shown, flagged).
NETWORK_TELEMETRY_STALE_AFTER_SECONDS=120
# Short-lived in-memory cache for the latest value (no history is persisted).
NETWORK_TELEMETRY_CACHE_TTL_SECONDS=15
# Optional global threshold overrides (percent); target is 70. critical must be >= warning.
# NETWORK_TELEMETRY_WARNING_PERCENT=80
# NETWORK_TELEMETRY_CRITICAL_PERCENT=90
# Prometheus (only used when NETWORK_TELEMETRY_MODE=prometheus). Read-only GET instant
# queries; HTTPS required outside development. The query is built ONLY from RADAR's central
# path mapping ($INTERFACE / $DIRECTION placeholders) — never from user input.
# PROMETHEUS_BASE_URL=https://prometheus.example.com
# PROMETHEUS_REQUEST_TIMEOUT_MS=5000
# PROMETHEUS_MAX_RETRIES=2
# PROMETHEUS_QUERY_PATH_UTILISATION=rate(ifHC$DIRECTIONOctets{ifName="$INTERFACE"}[5m])*8
# Prometheus auth is GENERIC and read from a mounted secret only (never env, never logged):
#   bearer: /run/secrets/prometheus_bearer_token
#   basic : /run/secrets/prometheus_basic_auth   (format: user:password)

# --- Réalta cache-pool / cache-node / origin telemetry (read-only, INFORMATIONAL) ------
# Never modifies NS1 or Cloudflare. disabled (default) / mock / prometheus. Reuses the same
# single Prometheus connection + auth as the network-path telemetry above.
CACHE_TELEMETRY_MODE=disabled
CACHE_TELEMETRY_STALE_AFTER_SECONDS=120
CACHE_TELEMETRY_CACHE_TTL_SECONDS=15
# Optional global threshold overrides (percent); critical must be >= warning.
# CACHE_TELEMETRY_WARNING_PERCENT=80
# CACHE_TELEMETRY_CRITICAL_PERCENT=90
# Prometheus query templates (only used when CACHE_TELEMETRY_MODE=prometheus). $POOL / $NODE
# are substituted server-side from RADAR's central pool/node config — never from user input.
# At minimum PROMETHEUS_QUERY_POOL_THROUGHPUT is required; others are optional (a missing
# template simply means that metric is not observed — never fabricated).
# PROMETHEUS_QUERY_POOL_THROUGHPUT=sum(rate(cache_out_bytes{pool="$POOL"}[5m]))*8
# PROMETHEUS_QUERY_POOL_CPU=avg(cache_cpu{pool="$POOL"})
# PROMETHEUS_QUERY_POOL_MEMORY=avg(cache_mem{pool="$POOL"})
# PROMETHEUS_QUERY_POOL_HIT_RATIO=avg(cache_hit_ratio{pool="$POOL"})
# PROMETHEUS_QUERY_POOL_REQUEST_RATE=sum(rate(cache_requests{pool="$POOL"}[5m]))
# PROMETHEUS_QUERY_NODE_THROUGHPUT=rate(cache_out_bytes{node="$NODE"}[5m])*8
# PROMETHEUS_QUERY_NODE_CPU=cache_cpu{node="$NODE"}
# PROMETHEUS_QUERY_ORIGIN_CPU=avg(origin_cpu)
# PROMETHEUS_QUERY_ORIGIN_REQUEST_RATE=sum(rate(origin_requests[5m]))
# PROMETHEUS_QUERY_ORIGIN_BANDWIDTH=sum(rate(origin_out_bytes[5m]))*8

# --- Tier-2 active DNS observation (read-only; verifies resolver answers vs prediction) --
# disabled (default) / mock (deterministic) / resolver (real read-only UDP DNS). RADAR never
# writes to NS1 or Cloudflare, runs only DNS queries (no HTTP/traceroute/QoE probes), and
# treats a single observation as one sample — never proof of the distribution or of traffic.
# Resolver addresses/ECS subnets are RADAR-owned config (see apps/api/src/dns-observation/
# scenarios.ts — currently RFC 5737 placeholders until RTÉ confirms real endpoints).
DNS_OBSERVATION_MODE=disabled
DNS_OBSERVATION_TIMEOUT_MS=3000
DNS_OBSERVATION_STALE_AFTER_SECONDS=900
# Optional periodic observation (OFF by default). The interval has a 60s floor so it can
# never probe aggressively; failures back off exponentially with per-ISP isolation.
DNS_OBSERVATION_PERIODIC_ENABLED=false
DNS_OBSERVATION_INTERVAL_SECONDS=900
DNS_OBSERVATION_CONCURRENCY=2
DNS_OBSERVATION_MAX_BACKOFF_SECONDS=3600

# --- NS1 live validation (read-only production-readiness check) ---------------
# Validation compares live/mock NS1 data against RADAR's runtime schemas, adapter and
# synthetic fixtures. It is READ-ONLY (never writes to NS1). Running it against a LIVE NS1
# account (RADAR_MODE=live) additionally requires this explicit opt-in — a controlled
# live-validation gate so live NS1 is never queried by accident. Mock-mode validation is
# always allowed. This never enables any NS1 write.
NS1_VALIDATION_ENABLED=false

# --- Auth: development mode (no IdP) -----------------------------------------
# NEVER enable in production — the API refuses to start with this under
# NODE_ENV=production unless the override below is deliberately set. Takes
# precedence over OIDC (OIDC is not attempted when this is true).
RADAR_DEV_AUTH=true
RADAR_DEV_USER_ID=dev-engineer
RADAR_DEV_USER_NAME=Development Engineer
RADAR_DEV_USER_EMAIL=dev-engineer@example.invalid
RADAR_DEV_ROLE=ENGINEER
# RADAR_ALLOW_DEV_AUTH_IN_PRODUCTION=false

# --- Auth: OIDC bearer-token validation (production; Entra ID / Keycloak) -----
# Enable in production (with RADAR_DEV_AUTH unset). radar-api validates the Entra
# access token on Authorization: Bearer <token>. See docs/security/entra-oidc.md.
OIDC_ENABLED=false
# Entra v2 issuer, e.g. https://login.microsoftonline.com/<tenant-guid>/v2.0
OIDC_ISSUER_URL=
# The RADAR API's Application ID URI or client id, e.g. api://radar
OIDC_AUDIENCE=
# Single-tenant restriction — tokens from other tenants are rejected.
OIDC_ALLOWED_TENANT_ID=
# Optional: skip discovery and set the JWKS URI explicitly.
# OIDC_JWKS_URI=
# Claim names (defaults suit Microsoft Entra ID):
# OIDC_SUBJECT_CLAIM=oid
# OIDC_FALLBACK_SUBJECT_CLAIM=sub
# OIDC_DISPLAY_NAME_CLAIM=name
# OIDC_EMAIL_CLAIM=preferred_username
# OIDC_ROLES_CLAIM=roles
# OIDC_TENANT_CLAIM=tid
# Entra app-role names mapped to the locked RADAR roles:
# OIDC_ROLE_NOC_VIEWER=RADAR.NOCViewer
# OIDC_ROLE_VIEWING_ENGINEER=RADAR.ViewingEngineer
# OIDC_ROLE_ENGINEER=RADAR.Engineer

# Frontend browser login (authorization-code + PKCE) is a future commit; radar-api
# itself only validates bearer tokens and needs no client secret.

# --- Database ----------------------------------------------------------------
# radar-api requires DATABASE_URL to start. Migrations are applied out-of-band
# (npm run migrate / the compose `radar-migrate` service), never automatically on boot.
# The connection string is never logged. See docs/architecture/persistence.md.
DATABASE_URL=postgres://radar:radar@postgres:5432/radar
# Optional pool tuning (defaults shown). Invalid values fail startup.
# DATABASE_POOL_MIN=0
# DATABASE_POOL_MAX=10
# DATABASE_CONNECTION_TIMEOUT_MS=5000
# DATABASE_IDLE_TIMEOUT_MS=30000
# DATABASE_STATEMENT_TIMEOUT_MS=15000

# --- API ---------------------------------------------------------------------
API_PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:8080

# --- Cloudflare Load Balancing (read-only; origin-pool selection downstream of NS1) ---------
# disabled (default) / live. Surfaces pools, origins, health and load-balancer steering policy.
# RADAR never writes to Cloudflare. Token is read from /run/secrets/cloudflare_api_token first
# (a read-only Custom token: Account→Load Balancing Read, Zone→Load Balancers Read, Zone→Analytics
# Read), then CLOUDFLARE_API_TOKEN for local dev only.
CLOUDFLARE_ENABLED=false
CLOUDFLARE_MODE=live
# CLOUDFLARE_ACCOUNT_ID=<account-id>
# CLOUDFLARE_API_TOKEN=            # dev only; prefer /run/secrets/cloudflare_api_token
# Zone names whose load balancers to read; empty = auto-discover (all non-reverse-DNS zones).
# CLOUDFLARE_LB_ZONES=rte.ie,rasset.ie,rte.host
CLOUDFLARE_POLL_INTERVAL_SECONDS=60
